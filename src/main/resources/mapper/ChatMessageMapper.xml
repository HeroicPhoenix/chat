<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lvwyh.chat.mapper.ChatMessageMapper">

    <resultMap id="ChatMessageResultMap" type="com.lvwyh.chat.entity.ChatMessage">
        <id property="id" column="id"/>
        <result property="conversationId" column="conversation_id"/>
        <result property="senderId" column="sender_id"/>
        <result property="messageType" column="message_type"/>
        <result property="contentCiphertext" column="content_ciphertext"/>
        <result property="contentIv" column="content_iv"/>
        <result property="contentVersion" column="content_version"/>
        <result property="createdAt" column="created_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <insert id="insert" parameterType="com.lvwyh.chat.entity.ChatMessage"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_message (
            conversation_id,
            sender_id,
            message_type,
            content_ciphertext,
            content_iv,
            content_version,
            created_at,
            deleted
        ) VALUES (
            #{conversationId},
            #{senderId},
            #{messageType},
            #{contentCiphertext},
            #{contentIv},
            #{contentVersion},
            NOW(),
            #{deleted}
        )
    </insert>

    <select id="selectRecentMessages" resultMap="ChatMessageResultMap">
        SELECT
            id,
            conversation_id,
            sender_id,
            message_type,
            content_ciphertext,
            content_iv,
            content_version,
            created_at,
            deleted
        FROM chat_message
        WHERE conversation_id = #{conversationId}
          AND deleted = 0
        ORDER BY created_at DESC, id DESC
        LIMIT #{limit}
    </select>

</mapper>