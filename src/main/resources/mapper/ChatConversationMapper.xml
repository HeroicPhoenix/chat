<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lvwyh.chat.mapper.ChatConversationMapper">

    <resultMap id="ChatConversationResultMap" type="com.lvwyh.chat.entity.ChatConversation">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="BaseColumnList">
        id,
        name,
        created_by,
        created_at
    </sql>

    <insert id="insert" parameterType="com.lvwyh.chat.entity.ChatConversation"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_conversation (
            name,
            created_by,
            created_at
        ) VALUES (
                     #{name},
                     #{createdBy},
                     NOW()
                 )
    </insert>

    <select id="selectById" resultMap="ChatConversationResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM chat_conversation
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectByUserId" resultMap="ChatConversationResultMap">
        SELECT c.id,
               c.name,
               c.created_by,
               c.created_at
        FROM chat_conversation c
                 INNER JOIN chat_conversation_member m
                            ON c.id = m.conversation_id
        WHERE m.user_id = #{userId}
        ORDER BY c.created_at DESC
    </select>

</mapper>