<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lvwyh.chat.mapper.ChatAttachmentMapper">

    <resultMap id="ChatAttachmentResultMap" type="com.lvwyh.chat.entity.ChatAttachment">
        <id property="id" column="id"/>
        <result property="messageId" column="message_id"/>
        <result property="storedName" column="stored_name"/>
        <result property="originalNameCiphertext" column="original_name_ciphertext"/>
        <result property="filePathCiphertext" column="file_path_ciphertext"/>
        <result property="mimeType" column="mime_type"/>
        <result property="fileSize" column="file_size"/>
        <result property="fileIv" column="file_iv"/>
        <result property="fileSha256" column="file_sha256"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.lvwyh.chat.entity.ChatAttachment"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_attachment (
            message_id,
            stored_name,
            original_name_ciphertext,
            file_path_ciphertext,
            mime_type,
            file_size,
            file_iv,
            file_sha256,
            created_at
        ) VALUES (
                     #{messageId},
                     #{storedName},
                     #{originalNameCiphertext},
                     #{filePathCiphertext},
                     #{mimeType},
                     #{fileSize},
                     #{fileIv},
                     #{fileSha256},
                     NOW()
                 )
    </insert>

    <select id="selectByMessageId" resultMap="ChatAttachmentResultMap">
        SELECT
            id,
            message_id,
            stored_name,
            original_name_ciphertext,
            file_path_ciphertext,
            mime_type,
            file_size,
            file_iv,
            file_sha256,
            created_at
        FROM chat_attachment
        WHERE message_id = #{messageId}
            LIMIT 1
    </select>

    <select id="selectById" resultMap="ChatAttachmentResultMap">
        SELECT
            id,
            message_id,
            stored_name,
            original_name_ciphertext,
            file_path_ciphertext,
            mime_type,
            file_size,
            file_iv,
            file_sha256,
            created_at
        FROM chat_attachment
        WHERE id = #{id}
            LIMIT 1
    </select>

</mapper>